{
  "manifest_version": 3,
  "name": "Overlai",
  "version": "0.1.0",
  "description": "Voice-driven generative overlay engine for live video",
  "permissions": ["activeTab", "storage", "scripting", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "trigger-overlai": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Activar Overlai por voz (oye sens)"
    }
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Overlai"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.ts"]
    }
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  }
}
